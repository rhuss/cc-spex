{
  "description": "spex plugin hooks for context injection and skill invocation enforcement",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "sh ${CLAUDE_PLUGIN_ROOT}/scripts/hooks/python-resolve.sh ${CLAUDE_PLUGIN_ROOT}/scripts/hooks/context-hook.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "sh ${CLAUDE_PLUGIN_ROOT}/scripts/hooks/python-resolve.sh ${CLAUDE_PLUGIN_ROOT}/scripts/hooks/pretool-gate.py"
          }
        ]
      }
    ]
  }
}
