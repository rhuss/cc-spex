{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-spex.dev/contracts/subagent-assignment.schema.json",
  "title": "Spex Subagent Assignment",
  "type": "object",
  "required": ["schema_version", "assignment_id", "kind", "workdir", "objective", "security_profile", "dependencies", "allowed_files", "required_evidence"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "assignment_id": { "type": "string", "minLength": 1 },
    "kind": { "enum": ["read", "write"] },
    "workdir": { "type": "string", "pattern": "^/" },
    "objective": { "type": "string", "minLength": 1 },
    "spec_context": { "type": "array", "items": { "type": "string" } },
    "task_ids": { "type": "array", "items": { "type": "string" } },
    "security_profile": { "enum": ["safe", "autonomous", "yolo"] },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "allowed_files": { "type": "array", "items": { "type": "string" } },
    "required_evidence": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "isolated_worktree": { "type": "boolean" }
  },
  "allOf": [{ "if": { "properties": { "kind": { "const": "write" } } }, "then": { "required": ["isolated_worktree"] } }],
  "additionalProperties": false
}
